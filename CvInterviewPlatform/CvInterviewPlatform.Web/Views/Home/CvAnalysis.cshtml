@model CvInterviewPlatform.Web.Models.User
@{
    ViewData["Title"] = "CV Analizim";
    bool analysisPending = ViewBag.AnalysisPending == true;
    string cvExt = System.IO.Path.GetExtension(Model.CvUrl ?? "").ToLowerInvariant();
    bool canPreviewInline = cvExt is ".pdf" or ".png" or ".jpg" or ".jpeg";
}

<!-- MarkedJS (Markdown render etmek için) CDN'i -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold text-body mb-1">CV Analizim</h1>
        <p class="text-body-secondary mb-0">Yapay zekanın özgeçmişinizden çıkardığı detaylı değerlendirme.</p>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.CvPreviewUrl))
    {
        if (canPreviewInline)
        {
            <button type="button" class="btn btn-outline-secondary btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#cvPreviewModal">
                <i class="bi bi-file-earmark-text me-1"></i> CV Dosyanı Görüntüle
            </button>
        }
        else
        {
            <a href="@ViewBag.CvPreviewUrl" target="_blank" class="btn btn-outline-secondary btn-sm fw-bold">
                <i class="bi bi-file-earmark-text me-1"></i> CV Dosyanı Görüntüle
            </a>
        }
    }
</div>

@if (string.IsNullOrEmpty(Model.CvContent))
{
    <div class="card border-0 shadow-sm p-4 p-lg-5 text-center">
        <i class="bi bi-clipboard2-x text-muted display-4 mb-3"></i>
        <h5 class="fw-bold text-body mb-2">Henüz bir CV yüklemediniz</h5>
        <p class="text-body-secondary mb-4">Yapay zeka analizini görebilmeniz için önce Ana Sayfa'dan özgeçmişinizi yükleyin.</p>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-gradient fw-bold">
                <i class="bi bi-cloud-arrow-up-fill me-1"></i> CV'mi Yükle
            </a>
        </div>
    </div>
}
else if (analysisPending)
{
    <div class="card border-0 shadow-sm rounded-4 p-4 p-lg-5 text-center" id="analysisLoadingCard">
        <div class="spinner-border text-primary mx-auto" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
        <h5 class="mt-3 fw-bold text-body">Analiziniz şu anda hazırlanıyor, lütfen bekleyin...</h5>
        <p class="text-body-secondary mb-0">Yapay zeka özgeçmişinizi inceliyor, bu işlem genelde 10-20 saniye sürüyor. Sayfayı yenilemenize gerek yok, hazır olunca otomatik görünecek.</p>
    </div>
    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 d-none" id="analysisResultCard">
        <div id="markdown-cv-analysis" class="text-body markdown-content"></div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
        <div id="markdown-cv-analysis" class="text-body markdown-content"></div>
        <div id="raw-cv-analysis" class="d-none">@Model.CvAnalysis</div>
    </div>
}

@if (canPreviewInline && !string.IsNullOrEmpty(ViewBag.CvPreviewUrl))
{
    <div class="modal fade" id="cvPreviewModal" tabindex="-1" aria-labelledby="cvPreviewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="cvPreviewModalLabel">CV Önizleme</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <div class="modal-body p-0" style="height: 75vh;">
                    <iframe src="@ViewBag.CvPreviewUrl" title="CV Önizleme" style="width: 100%; height: 100%; border: 0;"></iframe>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function renderMarkdown(markdown) {
                var targetDiv = document.getElementById("markdown-cv-analysis");
                if (targetDiv) {
                    targetDiv.innerHTML = marked.parse(markdown);
                }
            }

            var rawDiv = document.getElementById("raw-cv-analysis");
            if (rawDiv) {
                renderMarkdown(rawDiv.textContent);
                return;
            }

            var loadingCard = document.getElementById("analysisLoadingCard");
            var resultCard = document.getElementById("analysisResultCard");
            if (!loadingCard || !resultCard) {
                return;
            }

            // Gemini arka planda çalışıyor — hazır olana kadar birkaç saniyede bir
            // kontrol ediyoruz, kullanıcının F5'e basmasına gerek kalmıyor.
            var pollInterval = setInterval(function () {
                fetch("@Url.Action("CvAnalysisStatus", "Home")")
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (data.ready) {
                            clearInterval(pollInterval);
                            renderMarkdown(data.analysis);
                            loadingCard.classList.add("d-none");
                            resultCard.classList.remove("d-none");
                        }
                    })
                    .catch(function (err) {
                        console.error("CV analiz durumu sorgulanamadı:", err);
                    });
            }, 3000);
        });
    </script>
}
