@model CvInterviewPlatform.Web.Models.User
@{
    ViewData["Title"] = "Ana Panel";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    <div class="row">
        @* Sol Taraf: Profil Kartı *@
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm text-center p-4">
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img src="@Model.ProfilePictureUrl" class="rounded-circle img-thumbnail shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Profil Fotoğrafı" />
                    }
                    else
                    {
                        <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" class="rounded-circle img-thumbnail shadow-sm" style="width: 150px; height: 150px;" alt="Varsayılan Avatar" />
                    }
                </div>
                <h4 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted small">@@@Model.Username</p>
                <hr />
                <div class="text-start mb-3">
                    <p class="mb-1 text-muted small"><strong>E-posta:</strong></p>
                    <p class="fw-semibold">@Model.Email</p>
                    <p class="mb-1 text-muted small"><strong>Telefon:</strong></p>
                    <p class="fw-semibold">@Model.PhoneNumber</p>

                    <div class="d-grid gap-2 mt-3">
                        <a asp-action="Settings" asp-controller="Home" class="btn btn-outline-dark btn-sm fw-bold">
                            <i class="bi bi-gear-fill me-1"></i> Profil Ayarlarını Düzenle
                        </a>
                    </div>

                </div>
            </div>
        </div>

        @* Sağ Taraf: Dosya Yönetimi ve Süreçler *@
        <div class="col-md-8">
            <div class="card shadow-sm p-4 mb-4">
                <h4 class="fw-bold text-primary mb-3"><i class="bi bi-folder-symlink-fill"></i> Belgelerim ve Dosya Yükleme</h4>
                <p class="text-muted small">Profil fotoğrafınızı veya güncel CV (PDF) belgenizi buradan yükleyebilirsiniz. Dosyalar yerel sunucumuzda güvenle saklanır.</p>

                <form id="uploadForm" asp-action="UploadDocuments" asp-controller="Home" method="post" enctype="multipart/form-data" class="mt-3">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Profil Fotoğrafı Güncelle</label>
                            <input type="file" id="profilePictureInput" name="profilePicture" class="form-control" accept="image/*" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">CV Yükle (Sadece PDF)</label>
                            <input type="file" id="cvFileInput" name="cvFile" class="form-control" accept=".pdf" />
                        </div>
                    </div>
                    <button type="submit" id="saveBtn" class="btn btn-primary fw-bold mt-2"><i class="bi bi-cloud-arrow-up-fill"></i> Seçilen Dosyaları Kaydet</button>
                </form>

                <!-- Yükleniyor Spinner'ı -->
                <div id="uploadLoader" class="d-none text-center py-4">
                    <div class="spinner-border text-primary" role="status" style="width: 2.5rem; height: 2.5rem;">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <h5 class="mt-3 text-primary fw-bold" id="loaderMessage">Dosyalarınız İşleniyor...</h5>
                    <p class="text-muted small mb-0" id="loaderSubMessage">Lütfen bekleyin, sayfayı kapatmayın veya yenilemeyin.</p>
                </div>
            </div>

            <div class="card shadow-sm p-4">
                <h4 class="fw-bold text-success mb-3"><i class="bi bi-file-earmark-check-fill"></i> Mevcut CV Durumu</h4>
                @if (!string.IsNullOrEmpty(Model.CvUrl))
                {
                    <div class="alert alert-success d-flex align-items-center justify-content-between mb-0" role="alert">
                        <div>
                            <i class="bi bi-file-earmark-pdf-fill fs-4 me-2"></i>
                            <span class="fw-semibold">CV belgeniz sistemde yüklü durumda!</span>
                        </div>
                        <a href="@Model.CvUrl" target="_blank" class="btn btn-outline-success btn-sm fw-bold">
                            <i class="bi bi-eye-fill"></i> Görüntüle / İndir
                        </a>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mb-0" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i> Henüz bir CV belgesi yüklemediniz. Lütfen yukarıdaki panelden PDF formatında bir CV yükleyin.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var form = document.getElementById("uploadForm");
            var profileInput = document.getElementById("profilePictureInput");
            var cvInput = document.getElementById("cvFileInput");
            var loader = document.getElementById("uploadLoader");
            var loaderMessage = document.getElementById("loaderMessage");
            var loaderSubMessage = document.getElementById("loaderSubMessage");

            if (form) {
                form.addEventListener("submit", function(event) {
                    var cvSelected = cvInput && cvInput.files && cvInput.files.length > 0;
                    var profileSelected = profileInput && profileInput.files && profileInput.files.length > 0;

                    if (!cvSelected && !profileSelected) {
                        event.preventDefault();
                        alert("Lütfen yüklemek için en az bir dosya seçin.");
                        return;
                    }

                    // Formu gizle ve yükleniyor spinner'ını göster
                    form.classList.add("d-none");
                    loader.classList.remove("d-none");

                    // Seçime göre mesajı özelleştir
                    if (cvSelected) {
                        loaderMessage.textContent = "CV'niz Yapay Zeka Tarafından Analiz Ediliyor...";
                        loaderSubMessage.textContent = "Yapay zekamız CV metnini okuyor ve veritabanına kaydediyor. Bu işlem birkaç saniye sürebilir, lütfen sayfayı yenilemeyin veya kapatmayın.";
                    } else if (profileSelected) {
                        loaderMessage.textContent = "Profil Fotoğrafınız Güncelleniyor...";
                        loaderSubMessage.textContent = "Görsel yükleniyor, lütfen bekleyin.";
                    }
                });
            }
        });
    </script>
}