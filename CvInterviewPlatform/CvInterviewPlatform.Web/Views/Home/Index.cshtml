@model CvInterviewPlatform.Web.Models.User
@{
    ViewData["Title"] = "Ana Sayfa";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

@{
    var recentSessions = ViewBag.RecentSessions as List<CvInterviewPlatform.Web.Models.InterviewSession>;

    string RelativeTime(System.DateTime utc)
    {
        var span = System.DateTime.UtcNow - utc;
        if (span.TotalHours < 1) return "az önce";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} saat önce";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays} gün önce";
        return $"{(int)(span.TotalDays / 7)} hafta önce";
    }
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="hero-card p-lg-5 mb-4">
            <i class="bi bi-mic-fill hero-card-decor"></i>
            <h1 class="fw-bold mb-2 text-body">Mülakata hazır mısınız, @Model.FirstName?</h1>
            <p class="text-body-secondary mb-4" style="max-width: 30rem;">
                Yapay zeka destekli mülakat hazırlığınızın durumunu buradan takip edin, yeni bir
                oturum başlatarak kendinizi geliştirmeye devam edin.
            </p>
            <a asp-controller="Interview" asp-action="Index" class="btn btn-gradient btn-lg fw-bold">
                Mülakata Başla <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="card border-0 shadow-sm p-4 p-lg-5 mb-4">
            <div class="section-label mb-3">Performans Özeti</div>
            <div class="d-flex align-items-baseline gap-3 flex-wrap">
                <span class="fw-bold text-body" style="font-size: 2.5rem; line-height: 1;">@ViewBag.CompletedCount</span>
                <span class="text-body-secondary">Tamamlanan Mülakat</span>
            </div>
            <div class="mt-3">
                <span class="text-body-secondary small"><span class="status-dot"></span>@ViewBag.InProgressCount Devam Ediyor</span>
                @if (ViewBag.LastJobTitle != null)
                {
                    <span class="text-body-secondary small ms-4"><span class="status-dot status-dot-muted"></span>Son hedef: @ViewBag.LastJobTitle</span>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm p-4 p-lg-5">
            @if (!string.IsNullOrEmpty(Model.CvUrl))
            {
                <div class="list-row px-0" style="cursor: default;">
                    <span class="list-row-icon"><i class="bi bi-file-earmark-text-fill"></i></span>
                    <div class="flex-grow-1">
                        <div class="list-row-title">Özgeçmiş</div>
                        <div class="list-row-subtitle">@System.IO.Path.GetFileName(Model.CvUrl)</div>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm fw-bold" id="toggleUploadBtn">
                        <i class="bi bi-arrow-repeat me-1"></i>CV Güncelle
                    </button>
                </div>
            }
            else
            {
                <h5 class="fw-bold mb-2 text-body">Özgeçmiş</h5>
                <p class="text-body-secondary small mb-3">Yapay zekanın sizi tanıyabilmesi için CV'nizi yükleyin.</p>
            }

            <form id="uploadForm" asp-action="UploadCv" asp-controller="Home" method="post" enctype="multipart/form-data" class="mt-3 @(!string.IsNullOrEmpty(Model.CvUrl) ? "d-none" : "")">
                <div class="dropzone mb-3">
                    <i class="bi bi-cloud-arrow-up-fill dropzone-icon"></i>
                    <p class="fw-bold mb-1">CV'nizi buraya sürükleyin</p>
                    <p class="small text-body-secondary mb-3">veya bilgisayarınızdan seçin (PDF, DOCX, TXT, MD, PNG, JPG)</p>
                    <input type="file" id="cvFileInput" name="cvFile" class="form-control" accept=".pdf,.docx,.txt,.md,.png,.jpg,.jpeg" />
                </div>
                <button type="submit" id="saveBtn" class="btn btn-gradient fw-bold"><i class="bi bi-check2-circle me-1"></i> CV'yi Kaydet</button>
            </form>

            <!-- Yükleniyor Spinner'ı -->
            <div id="uploadLoader" class="d-none text-center py-4">
                <div class="spinner-border text-primary" role="status" style="width: 2.5rem; height: 2.5rem;">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
                <h5 class="mt-3 fw-bold">CV'niz Yapay Zeka Tarafından Analiz Ediliyor...</h5>
                <p class="text-body-secondary small mb-0">Yapay zekamız CV metnini okuyor ve veritabanına kaydediyor. Bu işlem birkaç saniye sürebilir, lütfen sayfayı yenilemeyin veya kapatmayın.</p>
            </div>

            @if (string.IsNullOrEmpty(Model.CvUrl))
            {
                <div class="alert alert-warning mt-3 mb-0 small" role="alert">
                    <i class="bi bi-exclamation-circle-fill me-2"></i> Henüz bir CV belgesi yüklemediniz.
                </div>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm p-4 p-lg-5 h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="section-label">Son Mülakatlar</span>
                <a asp-controller="Interview" asp-action="Index" class="small text-decoration-none fw-bold">Tümünü Gör</a>
            </div>

            @if (recentSessions == null || !recentSessions.Any())
            {
                <p class="text-body-secondary small mb-0">Henüz bir mülakat geçmişiniz yok. Soldaki bağlantıdan ilk mülakatınızı başlatabilirsiniz.</p>
            }
            else
            {
                <div>
                    @foreach (var session in recentSessions)
                    {
                        <a asp-controller="Interview" asp-action="Session" asp-route-id="@session.SessionId" class="list-row">
                            <span class="list-row-icon list-row-icon-ring"><i class="bi bi-mic-fill"></i></span>
                            <div class="flex-grow-1">
                                <div class="list-row-title">@session.JobTitle</div>
                                <div class="list-row-subtitle">@(session.Mode == "Realistic" ? "Gerçekçi" : "Hazırlık") &middot; @session.DifficultyLevel</div>
                                <span class="badge @(session.IsCompleted ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning-emphasis") border-0 mt-1" style="font-size: 0.68rem;">
                                    @(session.IsCompleted ? "Tamamlandı" : "Devam Ediyor")
                                </span>
                            </div>
                            <span class="list-row-meta">@RelativeTime(session.StartedAt)</span>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var form = document.getElementById("uploadForm");
            var cvInput = document.getElementById("cvFileInput");
            var loader = document.getElementById("uploadLoader");

            var toggleUploadBtn = document.getElementById("toggleUploadBtn");
            if (toggleUploadBtn && form) {
                toggleUploadBtn.addEventListener("click", function() {
                    form.classList.toggle("d-none");
                });
            }

            if (form) {
                form.addEventListener("submit", function(event) {
                    var cvSelected = cvInput && cvInput.files && cvInput.files.length > 0;

                    if (!cvSelected) {
                        event.preventDefault();
                        alert("Lütfen yüklemek için bir CV dosyası seçin.");
                        return;
                    }

                    // Formu gizle ve yükleniyor spinner'ını göster
                    form.classList.add("d-none");
                    loader.classList.remove("d-none");
                });
            }
        });
    </script>
}
