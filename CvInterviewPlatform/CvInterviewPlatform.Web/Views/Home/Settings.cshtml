@model CvInterviewPlatform.Web.Models.User
@{
    ViewData["Title"] = "Profil Ayarları";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white d-flex align-items-center justify-content-between py-3">
                    <h5 class="mb-0"><i class="bi bi-gear-fill me-2"></i> Hesap ve Profil Ayarları</h5>
                    <a asp-action="Index" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left"></i> Panele Dön</a>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="UpdateSettings" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Kullanıcı Adı (Değiştirilemez)</label>
                            <input type="text" class="form-control bg-light" value="@@@Model.Username" disabled />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Adınız</label>
                                <input type="text" name="firstName" class="form-control" value="@Model.FirstName" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Soyadınız</label>
                                <input type="text" name="lastName" class="form-control" value="@Model.LastName" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Gmail Adresi</label>
                            <input type="email" name="email" class="form-control" value="@Model.Email" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Telefon Numarası</label>
                            <input type="tel" name="phoneNumber" class="form-control" value="@Model.PhoneNumber" required />
                        </div>

                        <div class="card border-warning my-4">
                            <div class="card-header bg-light text-warning-dark fw-bold">
                                <i class="bi bi-lock-fill"></i> Güvenlik & Şifre Değiştirme
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-3">Şifrenizi değiştirmek istemiyorsanız bu alanı boş bırakabilirsiniz.</p>
                                <div class="mb-3">
                                    <label class="form-label">Mevcut Şifre</label>
                                    <input type="password" name="currentPassword" class="form-control" placeholder="Mevcut şifreniz" />
                                </div>
                                <div class="mb-0">
                                    <label class="form-label">Yeni Şifre</label>
                                    <input type="password" name="newPassword" class="form-control" placeholder="Yeni şifreniz" />
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold"><i class="bi bi-save-fill me-1"></i> Değişiklikleri Kaydet</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>