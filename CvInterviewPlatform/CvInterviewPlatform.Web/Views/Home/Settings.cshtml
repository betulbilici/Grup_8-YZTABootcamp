@model CvInterviewPlatform.Web.Models.User
@{
    ViewData["Title"] = "Hesap Ayarları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">Hesap Ayarları</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Panele Dön</a>
</div>

@if (ViewBag.Error != null || TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @(ViewBag.Error ?? TempData["Error"])
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (ViewBag.Success != null || TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @(ViewBag.Success ?? TempData["Success"])
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm p-4 p-lg-5 mb-4">
    <form asp-action="UploadProfilePicture" method="post" enctype="multipart/form-data" class="d-flex align-items-center gap-3 flex-wrap">
        <span class="avatar-status">
            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" alt="Profil Fotoğrafı" style="width:64px;height:64px;" />
            }
            else
            {
                <span class="avatar-fallback" style="width:64px;height:64px;font-size:1.4rem;">@Model.FirstName.Substring(0, 1).ToUpper()</span>
            }
        </span>
        <div class="flex-grow-1">
            <h4 class="fw-bold mb-0 text-body">@Model.FirstName @Model.LastName</h4>
            <div class="text-body-secondary small">@Model.Email</div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label for="profilePictureInput" class="visually-hidden">Profil fotoğrafı seç</label>
            <input type="file" id="profilePictureInput" name="profilePicture" class="form-control form-control-sm" accept=".png,.jpg,.jpeg,.webp" style="max-width: 220px;" />
            <button type="submit" class="btn btn-outline-secondary btn-sm fw-bold text-nowrap"><i class="bi bi-arrow-repeat me-1"></i>Fotoğrafı Güncelle</button>
        </div>
    </form>
</div>

<form asp-action="UpdateSettings" method="post">
    <div class="card border-0 shadow-sm p-4 p-lg-5 mb-4">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold mb-2 text-body">Kişisel Bilgiler</h5>
                <p class="text-body-secondary small mb-0">Mülakat senaryolarınızı kişiselleştirmek için kullanılan temel profil bilgileriniz.</p>
            </div>
            <div class="col-md-8">
                <div class="mb-4">
                    <label for="settingsUsername" class="section-label d-block mb-2">Kullanıcı Adı (Değiştirilemez)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body-secondary"><i class="bi bi-lock-fill"></i></span>
                        <input type="text" id="settingsUsername" class="form-control bg-body-secondary" value="@Model.Username" disabled />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="firstName" class="section-label d-block mb-2">Adınız</label>
                        <input type="text" id="firstName" name="firstName" class="form-control" value="@Model.FirstName" required aria-required="true" />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="lastName" class="section-label d-block mb-2">Soyadınız</label>
                        <input type="text" id="lastName" name="lastName" class="form-control" value="@Model.LastName" required aria-required="true" />
                    </div>
                </div>
                <div class="mb-4">
                    <label for="email" class="section-label d-block mb-2">Gmail Adresi</label>
                    <input type="email" id="email" name="email" class="form-control" value="@Model.Email" required aria-required="true" />
                </div>
                <div class="mb-4">
                    <label for="phoneNumber" class="section-label d-block mb-2">Telefon Numarası</label>
                    <input type="tel" id="phoneNumber" name="phoneNumber" class="form-control" value="@Model.PhoneNumber" required aria-required="true" />
                </div>
                <button type="submit" class="btn btn-gradient fw-bold"><i class="bi bi-save-fill me-1"></i> Bilgileri Kaydet</button>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-4 p-lg-5">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold mb-2 text-body">Güvenlik</h5>
                <p class="text-body-secondary small mb-0">Şifrenizi değiştirmek istemiyorsanız bu alanı boş bırakabilirsiniz.</p>
            </div>
            <div class="col-md-8">
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="currentPassword" class="section-label d-block mb-2">Mevcut Şifre</label>
                        <input type="password" id="currentPassword" name="currentPassword" class="form-control" placeholder="Mevcut şifreniz" />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label for="newPassword" class="section-label d-block mb-2">Yeni Şifre</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-control" placeholder="Yeni şifreniz" />
                    </div>
                </div>
                <button type="submit" class="btn btn-outline-secondary fw-bold"><i class="bi bi-key-fill me-1"></i> Şifreyi Güncelle</button>
            </div>
        </div>
    </div>
</form>
