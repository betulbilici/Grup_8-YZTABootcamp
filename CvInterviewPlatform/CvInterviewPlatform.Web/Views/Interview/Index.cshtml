@model List<CvInterviewPlatform.Web.Models.InterviewSession>
@{
    ViewData["Title"] = "Mülakat Portalı";
}

<div class="mb-4">
    <h1 class="h2 fw-bold mb-1">Yeni Mülakat Simülasyonu</h1>
    <p class="text-body-secondary mb-0">Hedef rolünüzü belirleyin ve gerçekçi bir mülakat deneyimine hazırlanın.</p>
</div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Yeni Mülakat Başlatma Kartı -->
        <div class="col-lg-4 col-md-5">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold mb-3 text-body"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Yeni Mülakat</h3>
                    <p class="text-muted small">Mülakat yapmak istediğiniz pozisyonu girerek 5 soruluk İK sürecini hemen başlatabilirsiniz.</p>
                    
                    <form asp-controller="Interview" asp-action="StartInterview" method="post" id="startInterviewForm">
                        <div class="mb-3">
                            <label for="jobTitle" class="form-label fw-semibold text-body">Hedef Pozisyon / Rol</label>
                            <input type="text" class="form-control form-control-lg border-2" id="jobTitle" name="jobTitle" placeholder="Örn: .NET Core Developer, Marketing Lead" required />
                        </div>

                        <div class="mb-3">
                            <span class="form-label fw-semibold text-body d-block">Mülakat Modu</span>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="mode-card card border-2 rounded-3 p-3 h-100 mb-0" for="modePreparation">
                                        <input class="visually-hidden" type="radio" name="mode" id="modePreparation" value="Preparation" checked />
                                        <span class="mode-card-icon"><i class="bi bi-mortarboard-fill"></i></span>
                                        <span class="fw-bold text-body d-block">Hazırlık Modu</span>
                                        <span class="small text-muted">Süre baskısı yok, ipucu alabilirsin, soruyu tekrar dinleyebilirsin.</span>
                                    </label>
                                </div>
                                <div class="col-6">
                                    <label class="mode-card card border-2 rounded-3 p-3 h-100 mb-0" for="modeRealistic">
                                        <input class="visually-hidden" type="radio" name="mode" id="modeRealistic" value="Realistic" />
                                        <span class="mode-card-icon"><i class="bi bi-lightning-fill"></i></span>
                                        <span class="fw-bold text-body d-block">Gerçekçi Mod</span>
                                        <span class="small text-muted">Soru başına 1 dakika, ipucu yok, gerçek mülakat temposu.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <span class="form-label fw-semibold text-body d-block">Zorluk Seviyesi</span>
                            <div class="row g-2">
                                <div class="col-4">
                                    <label class="mode-card card border-2 rounded-3 p-2 text-center h-100 mb-0" for="difficultyJunior">
                                        <input class="visually-hidden" type="radio" name="difficulty" id="difficultyJunior" value="Junior" />
                                        <span class="fw-bold text-body d-block small">Junior</span>
                                        <span class="small text-muted">Temel kavramlar</span>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="mode-card card border-2 rounded-3 p-2 text-center h-100 mb-0" for="difficultyMid">
                                        <input class="visually-hidden" type="radio" name="difficulty" id="difficultyMid" value="Mid" checked />
                                        <span class="fw-bold text-body d-block small">Mid</span>
                                        <span class="small text-muted">Uygulamalı senaryo</span>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="mode-card card border-2 rounded-3 p-2 text-center h-100 mb-0" for="difficultySenior">
                                        <input class="visually-hidden" type="radio" name="difficulty" id="difficultySenior" value="Senior" />
                                        <span class="fw-bold text-body d-block small">Senior</span>
                                        <span class="small text-muted">Mimari kararlar</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3" id="timeLimitGroup">
                            <label for="timeLimit" class="form-label fw-semibold text-body">Süre (Hazırlık Modu)</label>
                            <select class="form-select" name="timeLimit" id="timeLimit">
                                <option value="0">Süresiz</option>
                                <option value="300" selected>5 dakika</option>
                                <option value="600">10 dakika</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-gradient btn-lg w-100 fw-bold shadow-sm">
                            <i class="bi bi-play-fill me-1"></i> Mülakata Başla
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Mülakat Geçmişi -->
        <div class="col-lg-8 col-md-7">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold mb-3 text-body"><i class="bi bi-clock-history text-secondary me-2"></i>Mülakat Geçmişiniz</h3>
                    
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-clipboard2-x text-muted display-4"></i>
                            <p class="text-muted mt-3">Henüz gerçekleştirilmiş bir mülakatınız bulunmuyor. İlk mülakatınızı sol taraftan başlatabilirsiniz.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="bg-body-secondary">
                                    <tr>
                                        <th>Pozisyon</th>
                                        <th>Mod / Zorluk</th>
                                        <th>Tarih</th>
                                        <th>Soru Durumu</th>
                                        <th>Durum</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var session in Model)
                                    {
                                        <tr>
                                            <td>
                                                <span class="fw-bold text-body">@session.JobTitle</span>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(session.Mode))
                                                {
                                                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-2 py-1 me-1">@(session.Mode == "Realistic" ? "Gerçekçi" : "Hazırlık")</span>
                                                }
                                                @if (!string.IsNullOrEmpty(session.DifficultyLevel))
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle px-2 py-1">@session.DifficultyLevel</span>
                                                }
                                            </td>
                                            <td class="text-muted small">
                                                @session.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                            </td>
                                            <td>
                                                @if (session.IsCompleted)
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">@session.TotalQuestions / @session.TotalQuestions Tamamlandı</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1">@session.CurrentQuestionNumber / @session.TotalQuestions</span>
                                                }
                                            </td>
                                            <td>
                                                @if (session.IsCompleted)
                                                {
                                                    <span class="badge bg-success px-2 py-1"><i class="bi bi-check-circle me-1"></i>Değerlendirildi</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark px-2 py-1"><i class="bi bi-hourglass-split me-1"></i>Devam Ediyor</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="d-inline-flex gap-2">
                                                    @if (session.IsCompleted)
                                                    {
                                                        <a asp-action="Session" asp-route-id="@session.SessionId" class="btn btn-outline-primary btn-sm fw-bold">
                                                            <i class="bi bi-file-earmark-text me-1"></i>Sonuçları Gör
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="Session" asp-route-id="@session.SessionId" class="btn btn-warning btn-sm fw-bold text-dark">
                                                            <i class="bi bi-play-fill me-1"></i>Devam Et
                                                        </a>
                                                    }
                                                    
                                                    <form asp-action="DeleteSession" asp-route-id="@session.SessionId" method="post" onsubmit="return confirm('Bu mülakat geçmişini silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');" class="d-inline">
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Mülakat Geçmişini Sil">
                                                            <i class="bi bi-trash3-fill"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modeInputs = document.querySelectorAll('input[name="mode"]');
            var timeLimitGroup = document.getElementById("timeLimitGroup");

            function updateTimeLimitVisibility() {
                var realisticSelected = document.getElementById("modeRealistic").checked;
                timeLimitGroup.classList.toggle("d-none", realisticSelected);
            }

            modeInputs.forEach(function (input) {
                input.addEventListener("change", updateTimeLimitVisibility);
            });

            updateTimeLimitVisibility();
        });
    </script>
}
