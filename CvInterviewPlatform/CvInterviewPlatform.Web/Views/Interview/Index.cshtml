@model List<CvInterviewPlatform.Web.Models.InterviewSession>
@{
    ViewData["Title"] = "Mülakat Portalı";
}

<!-- Bootstrap Icons CDN linkini sayfa bazlı garantiye alıyoruz -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12 text-center text-md-start">
            <h1 class="display-5 fw-bold text-primary">Yapay Zeka Mülakat Portalı</h1>
            <p class="lead text-muted">Uzman yapay zekamız ile mülakat deneyimi yaşayın, kendinizi geliştirin.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Yeni Mülakat Başlatma Kartı -->
        <div class="col-lg-4 col-md-5">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold mb-3 text-dark"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Yeni Mülakat</h3>
                    <p class="text-muted small">Mülakat yapmak istediğiniz pozisyonu girerek 5 soruluk İK sürecini hemen başlatabilirsiniz.</p>
                    
                    <form asp-controller="Interview" asp-action="StartInterview" method="post">
                        <div class="mb-3">
                            <label for="jobTitle" class="form-label fw-semibold text-dark">Hedef Pozisyon / Rol</label>
                            <input type="text" class="form-control form-control-lg border-2" id="jobTitle" name="jobTitle" placeholder="Örn: .NET Core Developer, Marketing Lead" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                            <i class="bi bi-play-fill me-1"></i> Mülakata Başla
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Mülakat Geçmişi -->
        <div class="col-lg-8 col-md-7">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h3 class="card-title fw-bold mb-3 text-dark"><i class="bi bi-clock-history text-secondary me-2"></i>Mülakat Geçmişiniz</h3>
                    
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-clipboard2-x text-muted display-4"></i>
                            <p class="text-muted mt-3">Henüz gerçekleştirilmiş bir mülakatınız bulunmuyor. İlk mülakatınızı sol taraftan başlatabilirsiniz.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Pozisyon</th>
                                        <th>Tarih</th>
                                        <th>Soru Durumu</th>
                                        <th>Durum</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var session in Model)
                                    {
                                        <tr>
                                            <td>
                                                <span class="fw-bold text-dark">@session.JobTitle</span>
                                            </td>
                                            <td class="text-muted small">
                                                @session.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                            </td>
                                            <td>
                                                @if (session.IsCompleted)
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">5 / 5 Tamamlandı</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1">@session.CurrentQuestionNumber / 5</span>
                                                }
                                            </td>
                                            <td>
                                                @if (session.IsCompleted)
                                                {
                                                    <span class="badge bg-success px-2 py-1"><i class="bi bi-check-circle me-1"></i>Değerlendirildi</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark px-2 py-1"><i class="bi bi-hourglass-split me-1"></i>Devam Ediyor</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="d-inline-flex gap-2">
                                                    @if (session.IsCompleted)
                                                    {
                                                        <a asp-action="Session" asp-route-id="@session.SessionId" class="btn btn-outline-primary btn-sm fw-bold">
                                                            <i class="bi bi-file-earmark-text me-1"></i>Sonuçları Gör
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="Session" asp-route-id="@session.SessionId" class="btn btn-warning btn-sm fw-bold text-dark">
                                                            <i class="bi bi-play-fill me-1"></i>Devam Et
                                                        </a>
                                                    }
                                                    
                                                    <form asp-action="DeleteSession" asp-route-id="@session.SessionId" method="post" onsubmit="return confirm('Bu mülakat geçmişini silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');" class="d-inline">
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Mülakat Geçmişini Sil">
                                                            <i class="bi bi-trash3-fill"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
