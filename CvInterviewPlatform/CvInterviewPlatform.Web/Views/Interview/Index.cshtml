@model List<CvInterviewPlatform.Web.Models.InterviewSession>
@{
    ViewData["Title"] = "Mülakat Portalı";
}

<div class="mb-4">
    <h1 class="h2 fw-bold mb-1 text-body">Mülakat Portalı</h1>
    <p class="text-body-secondary mb-0">Sıradaki oturumunuzu yapılandırın. Hazırlanmaya başlamak için bir mod seçin.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
}

<div class="card border-0 shadow-sm p-4 p-lg-5 mb-4">
    <form asp-controller="Interview" asp-action="StartInterview" method="post" id="startInterviewForm">
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <label class="mode-card p-4 h-100 mb-0" for="modePreparation">
                    <input class="visually-hidden" type="radio" name="mode" id="modePreparation" value="Preparation" checked />
                    <span class="mode-card-icon"><i class="bi bi-mortarboard-fill"></i></span>
                    <span class="fw-bold text-body d-block fs-5 mb-1">Hazırlık Modu</span>
                    <span class="small text-body-secondary">Süre baskısı yok, ipucu alabilirsin, soruyu tekrar dinleyebilirsin.</span>
                    <span class="mode-card-select-indicator">SEÇİLİ <i class="bi bi-arrow-right"></i></span>
                </label>
            </div>
            <div class="col-md-6">
                <label class="mode-card p-4 h-100 mb-0" for="modeRealistic">
                    <input class="visually-hidden" type="radio" name="mode" id="modeRealistic" value="Realistic" />
                    <span class="mode-card-icon"><i class="bi bi-lightning-fill"></i></span>
                    <span class="fw-bold text-body d-block fs-5 mb-1">Gerçekçi Mod</span>
                    <span class="small text-body-secondary">Soru başına 1 dakika, ipucu yok, gerçek mülakat temposu.</span>
                    <span class="mode-card-select-indicator">SEÇİLİ <i class="bi bi-arrow-right"></i></span>
                </label>
            </div>
        </div>

        <div class="d-flex align-items-end gap-3 flex-wrap">
            <div class="flex-grow-1" style="min-width: 240px;">
                <label for="jobTitle" class="section-label d-block mb-2">Hedef Pozisyon / Rol</label>
                <input type="text" class="form-control form-control-lg rounded-pill px-4" id="jobTitle" name="jobTitle" placeholder="Örn: .NET Core Developer" required />
            </div>
            <div>
                <label for="difficulty" class="section-label d-block mb-2">Zorluk</label>
                <select class="select-pill" name="difficulty" id="difficulty">
                    <option value="Junior">Junior</option>
                    <option value="Mid" selected>Mid</option>
                    <option value="Senior">Senior</option>
                </select>
            </div>
            <div id="timeLimitGroup">
                <label for="timeLimit" class="section-label d-block mb-2">Süre</label>
                <select class="select-pill" name="timeLimit" id="timeLimit">
                    <option value="0">Süresiz</option>
                    <option value="300" selected>5 dakika</option>
                    <option value="600">10 dakika</option>
                </select>
            </div>
            <button type="submit" class="btn btn-gradient fw-bold px-4">
                Hazırlığa Başla <i class="bi bi-arrow-right ms-1"></i>
            </button>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm p-4 p-lg-5">
    <div class="section-label mb-4">Son Mülakatlar</div>

    @if (Model == null || !Model.Any())
    {
        <p class="text-body-secondary small mb-0">Henüz gerçekleştirilmiş bir mülakatınız bulunmuyor. Yukarıdan ilk mülakatınızı başlatabilirsiniz.</p>
    }
    else
    {
        <div>
            @foreach (var session in Model)
            {
                <div class="list-row" style="cursor: default;">
                    <span class="status-dot @(session.IsCompleted ? "status-dot-muted" : "")" style="flex-shrink: 0;"></span>
                    <div class="flex-grow-1">
                        <div class="list-row-title">@session.JobTitle</div>
                        <div class="list-row-subtitle">
                            @(session.Mode == "Realistic" ? "Gerçekçi" : "Hazırlık") &middot; @session.DifficultyLevel
                        </div>
                    </div>
                    <span class="list-row-meta me-3">@session.StartedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                    <div class="d-flex align-items-center gap-2">
                        @if (session.IsCompleted)
                        {
                            <a asp-action="Session" asp-route-id="@session.SessionId" class="btn btn-outline-secondary btn-sm fw-bold">Sonuçları Gör</a>
                        }
                        else
                        {
                            <a asp-action="Session" asp-route-id="@session.SessionId" class="btn btn-gradient btn-sm fw-bold">Devam Et</a>
                        }
                        <form asp-action="DeleteSession" asp-route-id="@session.SessionId" method="post" onsubmit="return confirm('Bu mülakat geçmişini silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Mülakat Geçmişini Sil">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modeInputs = document.querySelectorAll('input[name="mode"]');
            var timeLimitGroup = document.getElementById("timeLimitGroup");

            function updateTimeLimitVisibility() {
                var realisticSelected = document.getElementById("modeRealistic").checked;
                timeLimitGroup.classList.toggle("d-none", realisticSelected);
            }

            modeInputs.forEach(function (input) {
                input.addEventListener("change", updateTimeLimitVisibility);
            });

            updateTimeLimitVisibility();
        });
    </script>
}
