@model CvInterviewPlatform.Web.Models.InterviewSession
@{
    ViewData["Title"] = $"{Model.JobTitle} Mülakatı";
    int progressPercent = Model.IsCompleted ? 100 : (int)Math.Round((Model.CurrentQuestionNumber - 1) * 100.0 / Model.TotalQuestions);
}

<style>
    #sttBtn.recording {
        background-color: var(--app-danger) !important;
        color: #ffffff !important;
        border-color: var(--app-danger) !important;
        animation: pulseMic 1.5s infinite;
    }

    @@keyframes pulseMic {
        0% {
            box-shadow: 0 0 0 0 color-mix(in srgb, var(--app-danger) 40%, transparent);
        }
        70% {
            box-shadow: 0 0 0 10px color-mix(in srgb, var(--app-danger) 0%, transparent);
        }
        100% {
            box-shadow: 0 0 0 0 color-mix(in srgb, var(--app-danger) 0%, transparent);
        }
    }

    .timer-warning {
        color: var(--app-danger) !important;
        animation: blinkTimer 1s infinite;
    }

    @@keyframes blinkTimer {
        0% { opacity: 1; }
        50% { opacity: 0.4; }
        100% { opacity: 1; }
    }

    /* Faz 3 — animasyonlar kapatılabilir olmalı; kayıt/uyarı bilgisi zaten
       renk + metinle de taşındığı için hareket durunca bilgi kaybı olmuyor. */
    @@media (prefers-reduced-motion: reduce) {
        #sttBtn.recording, .timer-warning {
            animation: none;
        }
    }

    html[data-app-motion="off"] #sttBtn.recording,
    html[data-app-motion="off"] .timer-warning {
        animation: none;
    }
</style>

<!-- MarkedJS (Markdown render etmek için) CDN'i -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<!-- html2pdf.js (Değerlendirme Raporunu PDF İndirmek için) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div id="interviewSessionRoot"
     data-session-id="@Model.SessionId"
     data-current-question-number="@Model.CurrentQuestionNumber"
     data-is-completed="@Model.IsCompleted.ToString().ToLower()"
     data-job-title="@Model.JobTitle"
     data-mode="@Model.Mode"
     data-time-limit-seconds="@Model.TimeLimitSeconds">
    <!-- Üst Başlık ve Geri Dönüş Linki -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold text-body mb-1">@Model.JobTitle Mülakatı</h1>
            <p class="text-muted mb-0">Başlangıç: @Model.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Panale Dön
        </a>
    </div>

    @if (!Model.IsCompleted)
    {
        <!-- 1. MÜLAKAT DEVAM EDİYORSA -->
        <div class="row g-4">
            <div class="col-lg-8">
                <!-- Üst durum çubuğu: etiketler solda, soru sayısı/sayaç sağda -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-body-secondary text-body-secondary border-0 text-uppercase" style="font-size: 0.68rem; letter-spacing: 0.04em;">@(Model.Mode == "Realistic" ? "Gerçekçi" : "Hazırlık")</span>
                        <span class="badge bg-body-secondary text-body-secondary border-0 text-uppercase" style="font-size: 0.68rem; letter-spacing: 0.04em;">@Model.DifficultyLevel</span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        @if (Model.TimeLimitSeconds > 0)
                        {
                            <div class="d-flex align-items-center text-secondary fw-bold border border-secondary-subtle px-2 py-1 rounded" id="timerContainer" role="timer" style="font-size: 0.9rem;">
                                <i class="bi bi-hourglass-split me-1" id="timerIcon"></i>
                                <span id="countdownTimer">--:--</span>
                                <span id="timerWarningLabel" class="ms-1 d-none">Son 1 dakika</span>
                            </div>
                            <span id="timerAnnouncement" class="visually-hidden" aria-live="polite"></span>
                        }
                        <span class="section-label mb-0">Soru @Model.CurrentQuestionNumber / @Model.TotalQuestions</span>
                    </div>
                </div>
                <div class="progress mb-4" style="height: 4px; background-color: var(--app-border);">
                    <div class="progress-bar" role="progressbar" style="width: @progressPercent%; background: var(--app-gradient);"
                         aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <!-- Aktif Soru Alanı -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="section-label mb-0">İK Uzmanı (Kıdemli Yapay Zeka)</span>
                            <button type="button" id="ttsBtn" class="btn btn-outline-primary btn-sm rounded-circle" style="width: 36px; height: 36px; flex-shrink: 0;" title="Sesli Oku / Sustur" aria-pressed="false" aria-label="Soruyu sesli oku">
                                <i class="bi bi-volume-up-fill"></i>
                            </button>
                        </div>
                        <p class="fs-3 text-body fw-bold mb-4" id="questionText" aria-live="polite">
                            @Model.History[Model.CurrentQuestionNumber - 1].Question
                        </p>

                        @if (Model.Mode != "Realistic")
                        {
                            <div class="mb-4">
                                <button type="button" id="hintBtn" class="btn btn-link text-decoration-none fw-bold p-0 text-body-secondary">
                                    <i class="bi bi-lightbulb-fill me-1"></i> İpucu Al
                                </button>
                                <div id="hintBox" class="alert alert-warning small mt-2 d-none" role="status"></div>
                            </div>
                        }

                        <!-- Cevap Gönderme Formu -->
                        <form id="answerForm" asp-controller="Interview" asp-action="SubmitAnswer" method="post">
                            <input type="hidden" name="id" value="@Model.SessionId" />
                            <div class="mb-3">
                                <textarea class="form-control rounded-3" id="answer" name="answer" rows="5"
                                          placeholder="Cevabınızı buraya yazınız veya 'Sesli Yanıtla' ile konuşun..."
                                          required></textarea>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <button type="button" id="sttBtn" class="btn btn-link text-decoration-none fw-bold p-0 text-body-secondary" aria-pressed="false" aria-label="Sesli yanıt ver">
                                    <i class="bi bi-mic-fill me-1"></i> Sesli Yanıtla
                                </button>
                                <button type="submit" id="submitBtn" class="btn btn-gradient rounded-pill px-4 fw-bold">
                                    Cevabı Gönder <i class="bi bi-send-fill ms-1"></i>
                                </button>
                            </div>
                        </form>
                        <span id="recordingAnnouncement" class="visually-hidden" aria-live="assertive"></span>

                        <!-- Yükleniyor Göstergesi -->
                        <div id="loadingIndicator" class="d-none text-center py-4">
                            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Yükleniyor...</span>
                            </div>
                            <h5 class="mt-3 text-primary fw-bold">Cevabınız Değerlendiriliyor...</h5>
                            <p class="text-muted">İK Uzmanımız cevabınızı analiz ediyor ve bir sonraki adımı hazırlıyor. Lütfen bekleyin.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sağ Panel: Mülakat Geçmişi Akışı -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <span class="section-label d-block mb-3">Şimdiye Kadarki Akış</span>

                        @if (Model.CurrentQuestionNumber == 1)
                        {
                            <p class="text-muted small mb-0">Henüz mülakatın başındasınız. Cevap verdikçe geçmiş buraya yansıyacaktır.</p>
                        }
                        else
                        {
                            <div class="vstack gap-3" style="max-height: 450px; overflow-y: auto; padding-right: 5px;">
                                @for (int i = 0; i < Model.CurrentQuestionNumber - 1; i++)
                                {
                                    var step = Model.History[i];
                                    <div class="bg-body-secondary p-3 rounded-3">
                                        <p class="small fw-bold text-body mb-1">Soru @(i + 1)</p>
                                        <p class="small text-body-secondary mb-2">@step.Question</p>
                                        <p class="small fw-bold text-body mb-1">Cevabınız</p>
                                        <p class="small text-body-secondary mb-0 text-truncate">@step.Answer</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- 2. MÜLAKAT TAMAMLANDIYSA (DEĞERLENDİRME EKRANI) -->
        <div class="row g-4">
            <!-- Sol Sütun: Yapay Zeka İK Değerlendirmesi — raporun kendisi ekranın odak noktası -->
            <div class="col-lg-7">
                <div class="mb-3" data-html2canvas-ignore="true">
                    <span class="section-label">Değerlendirme Raporu</span>
                </div>
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5" id="evaluationCard">
                    <!-- Markdown render edilen alan -->
                    <div id="markdown-evaluation" class="text-body markdown-content"></div>

                    <!-- Raporu İndirme Butonları -->
                    <hr class="my-4" data-html2canvas-ignore="true">
                    <div class="d-flex gap-2 justify-content-end" data-html2canvas-ignore="true">
                        <button type="button" id="downloadTxtBtn" class="btn btn-outline-secondary btn-sm fw-bold">
                            <i class="bi bi-file-earmark-text-fill me-1"></i> Metin Olarak İndir (.txt)
                        </button>
                        <button type="button" id="downloadPdfBtn" class="btn btn-outline-secondary btn-sm fw-bold">
                            <i class="bi bi-file-pdf-fill me-1"></i> Raporu PDF Olarak İndir
                        </button>
                    </div>

                    <!-- Gizli ham markdown metni -->
                    <div id="raw-evaluation" class="d-none">@Model.FinalEvaluation</div>
                </div>
            </div>

            <!-- Sağ Sütun: Detaylı Mülakat Görüşme Geçmişi (Transcript) -->
            <div class="col-lg-5">
                <div class="mb-3">
                    <span class="section-label">Mülakat Görüşme Akışı</span>
                </div>
                <div class="vstack gap-3">
                    @for (int i = 0; i < Model.History.Count; i++)
                    {
                        var step = Model.History[i];
                        <div class="card border-0 shadow-sm rounded-4 p-3 p-lg-4">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <span class="fw-bold small text-body">Soru @(i + 1)</span>
                                <span class="text-body-secondary small">@step.AskedAt.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                            <div class="bg-primary-subtle text-primary-emphasis p-3 rounded-3 mb-3 small">
                                <strong>İK Uzmanı:</strong> @step.Question
                            </div>
                            <div class="bg-success-subtle text-success-emphasis p-3 rounded-3 small">
                                <strong>Cevabınız:</strong> @step.Answer
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/interview-session.js" asp-append-version="true"></script>
}
