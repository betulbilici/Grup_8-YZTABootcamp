<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CvInterviewPlatform.Web</title>
    <script>
        // FOUC (beyaz çakma) engeli: CSS'ten önce, senkron çalışıp data-bs-theme'i
        // ve erişilebilirlik tercihlerini (palet/yazı boyutu/animasyon) yazar.
        // Auth sayfalarında bu tercihleri değiştirecek bir panel yok, ama daha önce
        // ayarlanmış tercihler burada da korunsun diye okunuyor.
        (function () {
            try {
                var pref = localStorage.getItem("themePreference") || "system";
                var theme = pref === "system"
                    ? (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
                    : pref;
                document.documentElement.setAttribute("data-bs-theme", theme);
            } catch (e) {
                document.documentElement.setAttribute("data-bs-theme", "light");
            }

            try {
                var palette = localStorage.getItem("appPalette") || "default";
                if (palette !== "default") {
                    document.documentElement.setAttribute("data-app-palette", palette);
                }

                var fontSize = localStorage.getItem("appFontSize") || "normal";
                if (fontSize !== "normal") {
                    document.documentElement.setAttribute("data-app-fontsize", fontSize);
                }

                var motion = localStorage.getItem("appMotion") || "on";
                if (motion === "off") {
                    document.documentElement.setAttribute("data-app-motion", "off");
                }
            } catch (e) { }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CvInterviewPlatform.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @RenderBody()
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
