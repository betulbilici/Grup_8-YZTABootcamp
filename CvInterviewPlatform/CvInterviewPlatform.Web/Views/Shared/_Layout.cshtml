<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CvInterviewPlatform.Web</title>
    <script>
        // FOUC (beyaz çakma) engeli: CSS'ten önce, senkron çalışıp data-bs-theme'i yazar.
        (function () {
            try {
                var pref = localStorage.getItem("themePreference") || "system";
                var theme = pref === "system"
                    ? (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
                    : pref;
                document.documentElement.setAttribute("data-bs-theme", theme);
            } catch (e) {
                document.documentElement.setAttribute("data-bs-theme", "light");
            }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CvInterviewPlatform.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        @await Html.PartialAsync("_Sidebar")
        <div class="app-content">
            <div class="app-topbar">
                <h1 class="topbar-title text-body">@ViewData["Title"]</h1>
                <div class="topbar-actions">
                    <div class="dropdown theme-switcher">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="themeSwitcherBtn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Tema seç">
                            <i class="bi bi-circle-half"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="themeSwitcherBtn">
                            <li><button type="button" class="dropdown-item" data-theme-value="light"><i class="bi bi-sun-fill me-2"></i>Açık</button></li>
                            <li><button type="button" class="dropdown-item" data-theme-value="dark"><i class="bi bi-moon-stars-fill me-2"></i>Koyu</button></li>
                            <li><button type="button" class="dropdown-item" data-theme-value="system"><i class="bi bi-circle-half me-2"></i>Sistem</button></li>
                        </ul>
                    </div>
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <div class="dropdown">
                            <button type="button" class="topbar-user" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Kullanıcı menüsü">
                                <span class="avatar-status">
                                    <span class="avatar-fallback">@(Context.Session.GetString("FirstName")?.Substring(0, 1).ToUpper())</span>
                                </span>
                                <span class="small fw-semibold d-none d-sm-inline">@Context.Session.GetString("FirstName")</span>
                                <i class="bi bi-chevron-down small d-none d-sm-inline"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="Settings"><i class="bi bi-gear-fill me-2"></i>Ayarlar</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="SignOut"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
                            </ul>
                        </div>
                    }
                </div>
            </div>
            <main role="main">
                @RenderBody()
            </main>
            <footer class="app-footer mt-4 pt-3 border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="small text-body-secondary">&copy; 2026 <strong class="text-body">CV Match AI</strong> &middot; Grup 8, YZTA Bootcamp</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="small text-decoration-none fw-semibold">Gizlilik Politikası</a>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
