<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CvInterviewPlatform.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CvInterviewPlatform.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        @using Microsoft.AspNetCore.Http

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CvInterviewPlatform</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Interview" asp-action="Index">Mülakatlar</a>
                        </li>
                    </ul>

                    @* DİNAMİK OTURUM KONTROLÜ BAŞLANGICI *@
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("Username") != null)
                        {
                            @* Kullanıcı giriş yapmışsa burası çalışır *@
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-dark me-2 fw-bold">
                                    <i class="bi bi-person-circle me-1"></i> Hoş geldin, @Context.Session.GetString("FirstName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm fw-bold" asp-controller="Account" asp-action="SignOut">Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            @* Kullanıcı giriş yapmamışsa burası çalışır *@
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold me-2" asp-controller="Account" asp-action="SignIn">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm fw-bold px-3" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                    @* DİNAMİK OTURUM KONTROLÜ BİTİŞİ *@

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CvInterviewPlatform.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
