@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "_AuthLayout";
}

<div class="auth-shell">
    <div class="auth-hero d-none d-md-flex">
        <a class="sidebar-brand fs-4 mb-4" asp-controller="Home" asp-action="Index">CvInterviewPlatform</a>
        <h1 class="display-5 fw-bold mb-3">Şifrenizi mi<br />Unuttunuz?</h1>
        <p class="text-white-50">Endişelenmeyin, bilgilerinizi doğrulayarak hemen yeni bir şifre oluşturabilirsiniz. Güvenliğiniz için lütfen kayıtlı bilgilerinizi eksiksiz girin.</p>
    </div>
    <div class="auth-form-panel">
        <div class="auth-form-card">
            <h2 class="fw-bold mb-1">Şifre Sıfırlama</h2>
            <p class="text-body-secondary mb-4">Kimliğinizi doğrulamak için aşağıdaki alanları doldurun.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="post">

                <h6 class="text-uppercase small fw-bold text-body-secondary mb-3"><i class="bi bi-shield-lock-fill me-1"></i> Kimlik Doğrulama</h6>

                <div class="mb-3">
                    <label class="form-label fw-bold">Kullanıcı Adı</label>
                    <input type="text" name="username" class="form-control" placeholder="Örn: kadirssl" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Adınız</label>
                        <input type="text" name="firstName" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Soyadınız</label>
                        <input type="text" name="lastName" class="form-control" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Sistemde Kayıtlı Gmail</label>
                    <input type="email" name="email" class="form-control" placeholder="ornek@@gmail.com" required />
                </div>

                <div class="mb-4">
                    <label class="form-label">Telefon Numarası</label>
                    <input type="tel" name="phoneNumber" class="form-control" placeholder="05xxxxxxxxx" required />
                </div>

                <hr class="my-4" />

                <h6 class="text-uppercase small fw-bold text-body-secondary mb-3"><i class="bi bi-key-fill me-1"></i> Yeni Şifre Belirleme</h6>

                <div class="mb-3">
                    <label class="form-label fw-bold">Yeni Şifre</label>
                    <input type="password" name="newPassword" class="form-control" placeholder="******" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Yeni Şifre Tekrar</label>
                    <input type="password" name="confirmNewPassword" class="form-control" placeholder="******" required />
                </div>

                <button type="submit" class="btn btn-gradient btn-lg w-100 fw-bold">Kimliği Doğrula ve Şifreyi Güncelle</button>
            </form>

            <p class="text-center mt-4 mb-0">
                <a asp-action="SignIn" class="text-decoration-none fw-bold"><i class="bi bi-arrow-left me-1"></i> Giriş Sayfasına Dön</a>
            </p>
        </div>
    </div>
</div>
