@*@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-shield-lock-fill me-2"></i> Şifre Yenileme Güvenlik Duvarı</h4>
                </div>
                <div class="card-body p-4">

                    @* Hata Mesajı *@
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @* Başarı Mesajı *@
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <p class="text-muted small text-center mb-4">
                        Şifrenizi yenileyebilmek için sistemde kayıtlı olan 5 kimlik bilginizi de eksiksiz ve doğru girmeniz gerekmektedir.
                    </p>

                    <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Kullanıcı Adı</label>
                            <input type="text" name="username" class="form-control" placeholder="Örn: kadirssl" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Adınız</label>
                                <input type="text" name="firstName" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Soyadınız</label>
                                <input type="text" name="lastName" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Sistemde Kayıtlı Gmail</label>
                            <input type="email" name="email" class="form-control" placeholder="ornek@@gmail.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Telefon Numarası</label>
                            <input type="tel" name="phoneNumber" class="form-control" placeholder="05xxxxxxxxx" required />
                        </div>

                        <hr class="my-4">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-danger">Yeni Şifre</label>
                            <input type="password" name="newPassword" class="form-control" placeholder="******" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-danger">Yeni Şifre Tekrar</label>
                            <input type="password" name="confirmNewPassword" class="form-control" placeholder="******" required />
                        </div>

                        <button type="submit" class="btn btn-warning w-100 py-2 fw-bold text-dark">Kimliği Doğrula ve Şifreyi Güncelle</button>
                    </form>

                </div>
                <div class="card-footer text-center bg-light py-3">
                    <a asp-action="SignIn" class="text-decoration-none fw-bold"><i class="bi bi-arrow-left me-1"></i> Giriş Sayfasına Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>