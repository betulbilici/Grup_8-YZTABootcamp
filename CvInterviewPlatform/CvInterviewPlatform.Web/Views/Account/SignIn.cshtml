@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_AuthLayout";
}

<div class="auth-shell">
    <div class="auth-hero d-none d-md-flex">
        <span class="hero-glow" aria-hidden="true"></span>
        <a class="sidebar-brand fs-4 mb-4" asp-controller="Home" asp-action="Index">CV Match AI</a>
        <h1 class="display-5 fw-bold mb-3">Kariyerinizi<br /><span style="background:var(--app-gradient);-webkit-background-clip:text;background-clip:text;color:transparent;">Yapay Zeka</span> ile Şekillendirin.</h1>
        <p class="auth-hero-subtext">CV'nizi yükleyin, mülakatlara hazırlanın ve hayalinizdeki işe giden yolda yapay zeka destekli analizlerle öne çıkın.</p>
    </div>
    <div class="auth-form-panel">
        <div class="auth-form-card">
            <h2 class="fw-bold mb-1">Hoş Geldiniz</h2>
            <p class="text-body-secondary mb-4">Hesabınıza giriş yapın</p>

            @* Giriş hatalarını (Hatalı şifre/kullanıcı) burada yakalıyoruz *@
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="SignIn" asp-controller="Account" method="post">

                <div class="mb-3">
                    <label for="loginInput" class="form-label fw-bold">Kullanıcı Adı veya Gmail</label>
                    <input type="text" id="loginInput" name="loginInput" class="form-control form-control-lg" placeholder="Kullanıcı adı veya @@gmail.com" required aria-required="true" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-bold">Şifre</label>
                    <input type="password" id="password" name="password" class="form-control form-control-lg" placeholder="******" required aria-required="true" />
                </div>

                <div class="text-end mb-4">
                    <a asp-action="ForgotPassword" class="text-decoration-none small fw-bold">Şifremi Unuttum?</a>
                </div>

                <button type="submit" class="btn btn-gradient btn-lg w-100 fw-bold">Giriş Yap <i class="bi bi-arrow-right ms-1"></i></button>
            </form>

            <div class="auth-divider my-4"><span>veya</span></div>

            <a asp-controller="Account" asp-action="GoogleLogin" class="btn btn-outline-secondary btn-lg w-100 fw-bold">
                <i class="bi bi-google me-2"></i> Google ile Giriş Yap
            </a>

            <p class="text-center text-body-secondary mt-4 mb-0">
                Henüz hesabınız yok mu? <a asp-action="Register" class="text-decoration-none fw-bold">Yeni Hesap Açın</a>
            </p>
        </div>
    </div>
</div>