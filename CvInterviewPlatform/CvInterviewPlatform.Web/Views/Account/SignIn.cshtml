@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">Sisteme Giriş Yap</h4>
                </div>
                <div class="card-body p-4">

                    @* Giriş hatalarını (Hatalı şifre/kullanıcı) burada yakalıyoruz *@
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="SignIn" asp-controller="Account" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Kullanıcı Adı veya Gmail</label>
                            <input type="text" name="loginInput" class="form-control" placeholder="Kullanıcı adı veya @@gmail.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Şifre</label>
                            <input type="password" name="password" class="form-control" placeholder="******" required />
                        </div>

                        <div class="text-end mb-4">
                            <a asp-action="ForgotPassword" class="text-decoration-none small text-danger fw-bold">Şifremi Unuttum?</a>
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 fw-bold">Giriş Yap</button>
                    </form>

                </div>
                <div class="card-footer text-center bg-light py-3">
                    <span>Henüz hesabınız yok mu? <a asp-action="Register" class="text-decoration-none fw-bold">Yeni Hesap Açın</a></span>
                </div>
            </div>
        </div>
    </div>
</div>